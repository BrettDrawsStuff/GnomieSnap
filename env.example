# Local development — copy to .env

# Skip JFS signature verification for local testing
SKIP_JFS_VERIFICATION=1

# Your deployment URL (no trailing slash)
# SNAP_PUBLIC_BASE_URL=https://your-snap.vercel.app

# Turso persistent storage — omit to use in-memory
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-token-here

PORT=3003
